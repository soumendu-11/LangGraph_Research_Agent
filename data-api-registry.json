    }
  },
  "global_endpoints": [
    {
      "name": "ask_analyst",
      "path": "/ask-analyst",
      "description": "Answers analytical questions using semantic views per workflow per region.",
      "intent": "ask_analyst",
      "example_utterances": [
        "analyze production trends",
        "answer a question about fields",
        "summarize reservoir performance"
      ],
      "required_parameters": [
        "question",
        "semantic_model_name"
      ],
      "optional_parameters": [
        "messages"
      ],
      "region_agnostic": true
    },
    {
      "name": "layers_viewport",
      "path": "/layers/viewport",
      "description": "Fetches map layers for a viewport.",
      "intent": "map_layers_viewport",
      "example_utterances": [
        "show basins in Norway",
        "show map layers for this area",
        "load layers in the current viewport",
        "get layer data for this bbox"
      ],
      "required_parameters": [
        "workflow",
        "region"
      ],
      "optional_parameters": [
        "region",
        "country_name",
        "bbox_min_lng",
        "bbox_min_lat",
        "bbox_max_lng",
        "bbox_max_lat",
        "zoom",
        "cluster",
        "map_action",
        "groups",
        "layers",
        "limit",
        "offset"
      ],
      "parameter_metadata": {
        "country_name": {
          "type": "string",
          "description": "Country name filter",
          "sample_values": [
            "Oman",
            "UAE",
            "Saudi Arabia",
            "Qatar",
            "Kuwait"
          ]
        }
      },
      "region_agnostic": true
    }
